# =============================================================================
# MarketPilot AI — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://marketpilot:marketpilot@localhost:5432/marketpilot?schema=public"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-secret-in-production"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_YEARLY="price_..."
STRIPE_PRICE_ELITE_MONTHLY="price_..."
STRIPE_PRICE_ELITE_YEARLY="price_..."

# ── Strategy Engine ───────────────────────────────────────────────────────────
STRATEGY_ENGINE_URL="http://localhost:8000"

# ── Polymarket (Live Trading — requires eligibility) ─────────────────────────
POLYMARKET_API_URL="https://clob.polymarket.com"
POLYMARKET_GAMMA_URL="https://gamma-api.polymarket.com"
POLYMARKET_WS_URL="wss://ws-subscriptions-clob.polymarket.com/ws/market"
POLYMARKET_PRIVATE_KEY=""
POLYMARKET_API_KEY=""
POLYMARKET_API_SECRET=""
POLYMARKET_API_PASSPHRASE=""
POLYMARKET_CHAIN_ID="137"

# ── Email (optional) ─────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@marketpilot.ai"

# ── Sentry (optional) ────────────────────────────────────────────────────────
SENTRY_DSN=""

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
APP_URL="http://localhost:3000"
API_URL="http://localhost:3001"
