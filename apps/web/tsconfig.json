{
  "extends": "@marketpilot/config/tsconfig.nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@marketpilot/types": [
        "../../packages/types/src"
      ],
      "@marketpilot/ui": [
        "../../packages/ui/src"
      ]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
